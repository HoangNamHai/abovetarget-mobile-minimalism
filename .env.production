# Production-only public env overrides.
# Loaded ahead of `.env` when bundling in production mode (Release builds,
# `expo export`), so these values win over the dev defaults in `.env`.

# RevenueCat is LIVE in production (Task 8, 2026-06-27): store subscription
# products exist (App Store + Play), production keys are selected by build profile
# (src/config/revenuecat.ts), so the paywall + real billing are active.
# Kept in sync with the production build profile in eas.json.
EXPO_PUBLIC_REVENUECAT_ENABLED=true
