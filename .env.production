# Production-only public env overrides.
# Loaded ahead of `.env` when bundling in production mode (Release builds,
# `expo export`), so these values win over the dev defaults in `.env`.

# RevenueCat stays OFF in production until real App Store / Play subscription
# products exist. With this false, the paywall is hidden and every user is
# treated as premium (no SDK init, no purchases). Ship-as-free.
EXPO_PUBLIC_REVENUECAT_ENABLED=false
