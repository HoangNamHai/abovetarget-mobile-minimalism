# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# Only EXPO_PUBLIC_* vars are inlined into the app bundle (safe for client use).

# Clerk auth (Phase 5). Leave blank to keep the signed-out stub (auth dormant).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Sentry crash reporting (Phase 5). Leave blank to disable. Only reports in non-dev builds.
EXPO_PUBLIC_SENTRY_DSN=

# Set per build profile by eas.json (development | preview | production).
# EXPO_PUBLIC_ENV=development

# --- Build/release-only secrets (NOT EXPO_PUBLIC; used by tooling, not the app bundle) ---
# RevenueCat keys live in src/config/revenuecat.ts and stay inert while REVENUECAT_DISABLED=true.
# Google Play uploads need a service-account JSON (pc-api-*.json) — gitignored, supplied at release time.
# SENTRY_AUTH_TOKEN is used by the Sentry CLI during EAS builds to upload sourcemaps.
# SENTRY_AUTH_TOKEN=
